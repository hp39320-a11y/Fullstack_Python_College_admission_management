# Django Secret Key (Generate a random string for production)
SECRET_KEY="your-django-secret-key-here"

# Debug mode (True for development, False for production)
DEBUG=True

# Allowed Hosts (comma-separated list, e.g., localhost,127.0.0.1)
ALLOWED_HOSTS="127.0.0.1,localhost"

# Razorpay API Credentials
# Replace with valid credentials from your Razorpay Dashboard (https://dashboard.razorpay.com/)
RAZORPAY_KEY_ID="your-razorpay-key-id-here"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret-here"
